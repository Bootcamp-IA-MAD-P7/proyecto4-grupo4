# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# URL of the FastAPI backend that the browser will call at runtime.
#
# Local development (docker-compose.yml):
#   VITE_API_URL=http://localhost:8000
#
# Production (EC2, docker-compose.prod.yml):
#   VITE_API_URL=http://YOUR_EC2_PUBLIC_IP:8004
#
# This value is baked into the static bundle at build time by Vite.
# Set it as the GitHub Actions secret VITE_API_URL for CI/CD deployment.
VITE_API_URL=http://127.0.0.1:8000
