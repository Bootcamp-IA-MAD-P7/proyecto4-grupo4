# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# - Docker Compose (local dev):  use the service name "db" as host.
# - Local dev (no Docker):        use "localhost" and the mapped host port.
# - Production (EC2):             set via GitHub Actions secret DATABASE_URL.
DATABASE_URL=postgresql://unicorn_user:unicorn_pass@db:5432/unicorns

# Comma-separated list of origins the API allows for CORS.
# Leave empty to fall back to the default (http://localhost:5173).
# Production example: CORS_ORIGINS=http://YOUR_EC2_IP:3005
CORS_ORIGINS=

# External host port for the PostgreSQL container.
# Port 5432 may be occupied on the server; use 5434 as the external mapping.
# The API always connects to db:5432 internally — this only affects the host binding.
POSTGRES_HOST_PORT=5434
